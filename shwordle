#!/usr/bin/env bash

RESET="\e[0m"
GREEN="\e[42m"
YELLOW="\e[43m"
DEFAULT="\e[49m"

main() {
    echo "welcome to shwordle!"
    echo

    while true; do
        echo "Menu:"
        echo "1) Play"
        echo "2) Exit"

        read -p "Choose an option: " choice
        case "${choice}" in
            1)
                play
                echo
                echo "Would you like to play again?"
                ;;
            2)
                echo $'\nThanks for playing!'
                echo "Made by ahmadnaufalhakim"
                break
                ;;
            *)
                echo "Invalid choice! Please enter 1 or 2."
                ;;
        esac
    done
}

check() {
    target="$1"
    input="$2"

    declare -A count
    for (( i=0; i<5; i++ )); do
        (( count["${target:i:1}"]++ ))
    done
    result=( "" "" "" "" "" )

    # Pass 1: greens
    for (( i=0; i<5; i++ )); do
        if [[ "${input:i:1}" == "${target:i:1}" ]]; then
            result[$i]="${GREEN}${input:i:1}"
            (( count["${input:i:1}"]-- ))
        fi
    done

    # Pass 2: yellows & grays
    for (( i=0; i<5; i++ )); do
        if [[ -z "${result[$i]}" ]]; then
            letter="${input:i:1}"
            if (( count["$letter"] > 0 )); then
                result[$i]="${YELLOW}${input:i:1}"
                (( count["$letter"]-- ))
            else
                result[$i]="${DEFAULT}${input:i:1}"
            fi
        fi
    done

    IFS=""
    printf '%b\n' "${result[*]}${RESET}"
}

guess() {
    attempts="$1"
    target="$2"

    printf "Guess #%d: " "${attempts}" >&2

    local input=""
    local char
    
    # Save terminal settings
    stty -echo -icanon time 0 min 1

    while true; do
        IFS= read -r -n1 char

        # Enter key
        if [[ -z "${char}" && "${#input}" -eq 5 ]]; then
            # Temporarily delete the displayed input
            printf "\033[5D\033[K" >&2
            stty sane

            # Reprint the result to screen through stderr
            check "${target}" "${input}" >&2

            # Return the raw guess through stdout
            printf "%s" "${input}"
            return
        fi

        # Backspace
        if [[ "${char}" == $'\x7f' ]]; then
            if [[ -n "${input}" ]]; then
                input="${input::-1}"
                printf "\b \b" >&2
            fi
            continue
        fi

        if [[ "${char}" =~ [a-zA-Z] ]] && (( ${#input} < 5 )); then
            upper=$(printf "%s" "${char}" | tr '[:lower:]' '[:upper:]')
            input+="${upper}"
            printf "%s" "${upper}" >&2
        fi
    done
}

intrjctn() {
    local attempts="$1"
    case "${attempts}" in
        1)
            printf "%s" "Genius!"
            ;;
        2)
            printf "%s" "Magnificent!"
            ;;
        3)
            printf "%s" "Impressive!"
            ;;
        4)
            printf "%s" "Splendid!"
            ;;
        5)
            printf "%s" "Great!"
            ;;
        6)
            printf "%s" "Phew!"
            ;;
    esac
}

play() {
    clear
    local target="${words[RANDOM % ${#words[@]}]}"

    local attempts=1
    while (( attempts <= 6 )); do
        guess_word=$(guess "${attempts}" "${target}")
        if [[ "${guess_word}" == "${target}" ]]; then # problem is here
            echo "$(intrjctn "${attempts}") You win!"
            return
        fi

        (( attempts++ ))
    done

    echo "Out of tries! The word was: ${target}"
}

read -r -d '' WORD_LIST <<'EOM'
ABCDE
FGHIJ
KLMNO
PQRST
UVWXY
ZZXYZ
EOM
mapfile -t words <<< "${WORD_LIST}"

main
